<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外部存储文件路径配置 - 用于 Android 16+ 文件共享 -->
    <external-files-path name="my_files" path="." />
    <cache-path name="cache" path="." />
    <external-cache-path name="external_cache" path="." />
    <files-path name="files" path="." />
    <!-- 分享目录 -->
    <cache-path name="share" path="share/" />
    <!-- APK下载目录 - 用于应用内更新安装 -->
    <external-path name="downloads" path="Android/data/com.acuspic.app/files/Acuspic/Downloads/" />
    <external-files-path name="apk_downloads" path="Acuspic/Downloads/" />
</paths>
