<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tool Button Style - 优化的格式工具按钮 -->
    <style name="ToolButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">@drawable/bg_tool_button</item>
        <item name="android:padding">8dp</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="tint">@color/dark_text_primary</item>
    </style>

    <!-- Aligned Action Button Styles - 优化的底部按钮 (Material Design 3) -->
    <style name="AlignedActionButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">10dp</item>
        <item name="iconGravity">top</item>
        <item name="iconPadding">2dp</item>
        <item name="iconSize">20dp</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="AlignedActionButton.Primary" parent="AlignedActionButton">
        <item name="android:backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="iconTint">@android:color/white</item>
    </style>

    <style name="AlignedActionButton.Secondary" parent="AlignedActionButton">
        <item name="android:backgroundTint">@color/dark_button_bg</item>
        <item name="android:textColor">@color/dark_text_primary</item>
        <item name="iconTint">@color/dark_text_primary</item>
    </style>

    <!-- 禁用状态样式 -->
    <style name="AlignedActionButton.Disabled" parent="AlignedActionButton">
        <item name="android:backgroundTint">@color/dark_button_disabled</item>
        <item name="android:textColor">@color/dark_text_disabled</item>
        <item name="iconTint">@color/dark_text_disabled</item>
        <item name="android:enabled">false</item>
    </style>

    <!-- Legacy Action Button Styles (保留用于兼容性) -->
    <style name="ActionButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">6dp</item>
        <item name="iconSize">18dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ActionButton.Primary" parent="ActionButton">
        <item name="android:backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="iconTint">@android:color/white</item>
        <item name="strokeColor">@color/accent_primary</item>
    </style>

    <style name="ActionButton.Secondary" parent="ActionButton">
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/dark_text_primary</item>
        <item name="iconTint">@color/dark_text_primary</item>
        <item name="strokeColor">@color/dark_button_border</item>
    </style>

    <!-- Light theme action buttons -->
    <style name="ActionButton.Secondary.Light" parent="ActionButton">
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/light_text_primary</item>
        <item name="iconTint">@color/light_text_primary</item>
        <item name="strokeColor">@color/light_button_border</item>
    </style>
</resources>
